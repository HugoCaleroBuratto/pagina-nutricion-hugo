# Supabase — copiar a .env y completar con los valores del proyecto
# Obtener en https://supabase.com → tu proyecto → Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# IMPORTANTE: la SERVICE_ROLE_KEY nunca debe estar en este archivo
# ni en el bundle del cliente. Solo se usa en scripts/seedFoods.js
# y debe quedarse en .env.local (que está en .gitignore).
